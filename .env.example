# ==============================================================================
# API keys (Required)
# ==============================================================================
OPENAI_API_KEY=   # Enter your openai api key


# ==============================================================================
# Directories 
# ==============================================================================
# DATA_DIR=/abs/path/to/data
# MODELS_DIR=/abs/path/to/models
# RESULTS_DIR=/abs/path/to/results
# LOGS_DIR=/abs/path/to/logs


# ==============================================================================
# BERT defaults
# ==============================================================================
# BERT_MODEL_PATH=ZongqianLi/matbert-base-uncased
# BERT_BATCH_SIZE=32
# BERT_LR=2e-5
# BERT_EPOCHS=3
# BERT_MAX_LEN=256


# ==============================================================================
# GPT defaults
# ==============================================================================
# GPT_MODEL_NAME=gpt-4o
# GPT_TEMPERATURE=0.0
# GPT_MAX_TOKENS=1000


# ==============================================================================
# RAG
# ==============================================================================
# JSON dataset settings
RAG_JSON_COLLECTION=sciqa_json
RAG_JSON_PERSIST_DIR=./.chroma_json
RAG_JSON_DATA_PATH=./dataset/dataset_json

# HTML dataset settings
RAG_HTML_COLLECTION=sciqa_html
RAG_HTML_PERSIST_DIR=./.chroma_html
RAG_HTML_DATA_PATH=./dataset/dataset_html
# RAG_HTML_CHUNK_SIZE=300

# QA evaluation CSV (shared by both JSON and HTML)
RAG_QA_CSV_PATH=./testset/rag_doi_testset.csv
# RAG_RAGAS_CSV_PATH=./testset/ragas_descriptive_testset.csv

# ==============================================================================
# Embedding / LLM model overrides for RAG
# ==============================================================================
# RAG_EMBED_MODEL=text-embedding-3-large
# RAG_EMBED_DIMENSIONS=3072
# RAG_LLM_MODEL=gpt-4o
# RAG_INSUFFICIENCY_CHECK_MODEL=gpt-4o-mini


# ==============================================================================
# HoneyBee (Materials Science LLM) - Optional
# ==============================================================================
# HONEYBEE_BASE_MODEL_PATH=honeybee/llama-7b-hf
# HONEYBEE_LORA_PATH=honeybee/7b
# HONEYBEE_LOAD_IN_8BIT=true
# HONEYBEE_LOAD_IN_4BIT=false
# HONEYBEE_MAX_NEW_TOKENS=512


# ==============================================================================
# LLaMA 3.3-70B (via Vertex AI Model Garden MaaS) - Optional
# ==============================================================================
# LLAMA_PROJECT_ID=your-gcp-project-id
# LLAMA_LOCATION=us-central1
# LLAMA_MODEL_ID=meta/llama-3.3-70b-instruct-maas
# LLAMA_MAX_TOKENS=1000
# LLAMA_TEMPERATURE=0.0
